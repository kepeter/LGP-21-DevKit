{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "lib": [
            "ES2020"
        ],
        "outDir": "out",
        "strict": true,
        "sourceMap": true
    },
    "include": [
        "extension.ts",
        "server/**/*.ts",
        "shared/**/*.ts",
        "compiler/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "out",
        "server/out"
    ]
}