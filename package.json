{
    "name": "lgp21devkit",
    "displayName": "LGP-21 DevKit",
    "description": "Development Kit for the LGP-21 Computer",
    "publisher": "kepeter",
    "icon": "images/icon.png",
    "version": "0.1.1",
    "engines": {
        "vscode": "^1.120.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/kepeter/LGP-21-DevKit"
    },
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "lgp21",
                "aliases": [
                    "lgp21",
                    "LGP-21"
                ],
                "extensions": [
                    "lgp21"
                ],
                "configuration": "./syntax/configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "lgp21",
                "scopeName": "source.lgp21",
                "path": "./syntax/grammar.json"
            }
        ],
        "taskDefinitions": [
            {
                "type": "lgp21-build",
                "properties": {}
            }
        ],
        "commands": [
            {
                "command": "lgp21.openManual",
                "title": "Open Programming Manual",
                "category": "LGP-21"
            },
            {
                "command": "lgp21.openExample",
                "title": "Open Example",
                "category": "LGP-21"
            }
        ]
    },
    "configurationDefaults": {
        "[lgp21]": {
            "editor.formatOnSave": true,
            "editor.formatOnPaste": true
        }
    },
    "scripts": {
        "vscode:prepublish": "node esbuild.js --production",
        "compile": "node esbuild.js",
        "watch": "node esbuild.js --watch",
        "typecheck": "tsc -b --noEmit",
        "clean": "tsc -b --clean"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.12"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/vscode": "^1.120.0",
        "esbuild": "^0.28.0",
        "typescript": "^5.7.0"
    }
}